{
  "name": "korean-product-ui",
  "private": false,
  "version": "0.1.0",
  "description": "Reusable React primitives and tokens for quiet Korean product interfaces.",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "src/*.css"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./components.css": "./dist/components.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/*.css dist/",
    "dev:example": "npm run dev --prefix examples/korean-product-page",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.2.0 || >=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "typescript": "~5.9.3"
  }
}
